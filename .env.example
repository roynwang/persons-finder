# Copy to .env and adjust. .env is gitignored.
POSTGRES_DB=persons_finder
POSTGRES_USER=persons_finder
POSTGRES_PASSWORD=change-me
APP_PORT=8080

# Google Gemini (AI bio generation). Leave GEMINI_API_KEY empty to disable
# generation entirely (persons are created with bio = null).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
